{
  "name": "communiverse-bot",
  "version": "1.0.0",
  "description": "Feature-complete AI-augmented Discord bot for Elio/Pixar communities",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/src/index.js",
    "start:build": "npm run build && node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "admin:dev": "tsx watch src/admin-app/index.ts",
    "admin:start": "node dist/src/admin-app/index.js",
    "admin:web:dev": "vite --config admin-web/vite.config.ts",
    "admin:web:build": "vite build --config admin-web/vite.config.ts",
    "build:ts": "node scripts/clean-dist.js && tsc -p tsconfig.json",
    "build": "npm run build:ts && node scripts/copy-build-assets.js",
    "admin:build": "npm run build:ts && npm run admin:web:build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy-commands": "node dist/scripts/deploy-commands.js",
    "deploy:dev": "node dist/scripts/deploy-commands.js",
    "deploy:global": "node dist/scripts/deploy-commands-global.js",
    "seed": "node dist/scripts/seed-data.js",
    "seed:all": "node dist/scripts/seed-all-docker.js",
    "seed:personas": "node dist/scripts/seed-personas.js",
    "seed:greetings": "node dist/scripts/seed-greetings.js",
    "seed:scenarios": "node dist/scripts/seed-scenarios.js",
    "seed:media": "node dist/scripts/seed-media.js",
    "seed:points": "node dist/scripts/seed-points.js",
    "seed:minigames": "node dist/scripts/seed-minigames.js",
    "metrics": "node dist/scripts/compute-user-metrics.js",
    "reset:leaderboard": "node dist/scripts/reset-leaderboards.js",
    "reset:achievements": "node dist/scripts/reset-achievements.js",
    "cron:maintenance": "node dist/scripts/cron-maintenance.js",
    "verify": "node dist/scripts/verify-setup.js",
    "seed:docker": "docker exec elioverse-bot-bot-1 node dist/scripts/seed-personas.js && docker exec elioverse-bot-bot-1 node dist/scripts/seed-greetings.js && docker exec elioverse-bot-bot-1 node dist/scripts/seed-media.js && docker exec elioverse-bot-bot-1 node dist/scripts/seed-points.js",
    "test": "node --import tsx --test tests/*.test.js",
    "test:games": "node --import tsx --test tests/minigames.test.js",
    "test:engagement": "node --import tsx --test tests/engagement.test.js",
    "test:integration": "node --import tsx --test tests/integration/*.test.js",
    "test:e2e": "node --import tsx --test tests/e2e/*.test.js",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "ingest:rag": "node dist/scripts/ingest-rag.js",
    "test:rag": "node dist/scripts/rag-smoketest.js",
    "ensure-indexes": "node dist/src/db/ensure-indexes.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "mongodb": "^6.3.0",
    "nanoid": "^5.1.6",
    "node-cron": "^3.0.3",
    "openai": "^6.5.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@mui/x-data-grid": "^8.23.0",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-codemirror": "^4.25.4",
    "@vitejs/plugin-react": "^5.1.2",
    "plotly.js-dist-min": "^3.3.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "keywords": [
    "discord",
    "bot",
    "elio",
    "communiverse",
    "ai"
  ],
  "author": "",
  "license": "MIT"
}
