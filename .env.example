# ============================================================================
# Elioverse Bot - Consolidated Environment Variables
# Discord Bot + Python AI Service Configuration
# ============================================================================

# -------------------------
# Discord Configuration
# -------------------------
DISCORD_TOKEN=your_bot_token_here
APP_ID=your_app_id_here
GUILD_ID_DEV=your_dev_guild_id_here

# -------------------------
# Database Configuration
# -------------------------
MONGODB_URI=mongodb://localhost:27017
DB_NAME=communiverse_bot

# -------------------------
# Shared Warehouse Configuration
# All models, datasets, and cache stored in shared warehouse
# IMPORTANT: This path must be accessible to both Bot and AI Service
# -------------------------
AI_WAREHOUSE_ROOT=/mnt/c/AI_LLM_projects/ai_warehouse

# -------------------------
# AI Configuration
# -------------------------
AI_ENABLED=false
AI_MODEL_TEXT=deepseek
AI_MODEL_VLM=qwen-vl
EMBEDDINGS_MODEL=bge-m3
AI_MOCK_MODE=false
AI_MOCK_LATENCY_MS=0

# AI Service Connection (for microservice architecture)
AI_SERVICE_URL=http://localhost:8000
# Increased timeout for embedding operations (RAG ingestion needs more time)
AI_SERVICE_TIMEOUT_MS=180000
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=2048

# llama.cpp Server Configuration (GPU inference on live4.dothost.net)
# GPU: NVIDIA GTX 1050 Ti (4GB VRAM), Model: Mistral-7B-Instruct Q4_K_M
USE_LLAMA_SERVER=false
LLAMA_SERVER_URL=http://live4.dothost.net:8080
LLAMA_TIMEOUT_MS=180000

# -------------------------
# Fine-Tuned Model Configuration
# -------------------------
FINETUNED_MODEL_ENABLED=true
FINETUNED_BASE_MODEL=deepseek-ai/deepseek-llm-7b-chat
FINETUNED_ADAPTER_PATH=/mnt/c/web-projects/elioverse-bot/models/sft_lora_balanced
FINETUNED_USE_FOR_PERSONAS=true

# RAG Configuration
RAG_TOP_K=5
RAG_MIN_SCORE=0.7
RAG_INDEX_NAME=vector_index

# Agent Configuration
AGENT_MAX_STEPS=10
AGENT_STEP_TIMEOUT_MS=15000

# Web Search Configuration
WEB_SEARCH_ENABLED=false
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_RATE_LIMIT=10

# Scheduler Configuration
NEWS_DIGEST_CRON=0 13 * * *

# Logging & Metrics
LOG_LEVEL=info
METRICS_PORT=9090

# -------------------------
# Bot Internal Admin API (Optional, for runtime bridge)
# -------------------------
# Enable minimal HTTP admin API served by the bot process
BOT_ADMIN_ENABLED=false
# Use 0.0.0.0 inside Docker if you publish ports
BOT_ADMIN_HOST=127.0.0.1
BOT_ADMIN_PORT=3001
# If set, require `Authorization: Bearer <token>` for all bot-admin routes
BOT_ADMIN_TOKEN=

# -------------------------
# Admin Web (Separate Service)
# -------------------------
# Starts a separate web server (Discord OAuth + dashboard UI).
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=3030
# Where to redirect the browser after OAuth login
# - Dev (Vite): http://localhost:5173
# - Docker/Prod: http://localhost:3030 (or your public domain)
ADMIN_WEB_ORIGIN=http://localhost:3030

# Discord OAuth2 (create an OAuth2 client in Discord Developer Portal)
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
# Scopes used for "Login with Discord" (recommended: identify guilds)
DISCORD_OAUTH_SCOPES=identify guilds
# Bot permission integer used for guild install flows (scope includes `bot`)
# Default `8` = Administrator (matches docs/SLASH_COMMANDS_DEPLOYMENT.md).
DISCORD_OAUTH_PERMISSIONS=8
# Must match the redirect URL configured in Discord portal
DISCORD_OAUTH_REDIRECT_URI=http://localhost:3030/auth/discord/callback

# Optional: runtime-bridge to the bot-internal admin API
BOT_ADMIN_URL=http://localhost:3001

# Privacy & Safety
MEMORY_TTL_DAYS=90
CONVERSATION_MAX_TURNS=50

# Feature Flags
KEYWORD_TRIGGERS_ENABLED=false
NSFW_FILTER_ENABLED=true

# -------------------------
# RAG Configuration (New)
# -------------------------
RAG_EMBEDDING_MODEL=bge-m3
RAG_EMBEDDING_DIM=1024
RAG_TOPK=8
RAG_MMR_LAMBDA=0.35
RAG_MIN_SCORE=0.25

# -------------------------
# Job Schedules (Cron Expressions)
# -------------------------
COSMIC_DIGEST_CRON=0 10 * * *
MEDIA_SWEEP_CRON=0 */6 * * *
SCENARIO_CRON=0 */4 * * *
DAILY_SUMMARY_CRON=0 23 * * *

# -------------------------
# Message Router Configuration
# -------------------------
RELEVANCE_THRESHOLD=0.6

# -------------------------
# Channel History Configuration
# -------------------------
# Enable/disable channel message history collection
CHANNEL_HISTORY_ENABLED=true
# Cron schedule for history sync (default: every 6 hours)
CHANNEL_HISTORY_CRON=0 */6 * * *
# Maximum days of history to fetch (default: 7)
CHANNEL_HISTORY_MAX_DAYS=7
# Days to retain messages before TTL deletion (default: 90)
CHANNEL_HISTORY_RETENTION_DAYS=90
